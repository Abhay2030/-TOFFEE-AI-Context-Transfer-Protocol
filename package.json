{
  "name": "toffee",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Toffee — AI Context Transfer Protocol",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:extension": "npm run dev --workspace=packages/extension",
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:web": "npm run dev --workspace=packages/web",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run migrate --workspace=packages/backend up",
    "build": "turbo run build",
    "build:extension": "npm run build --workspace=packages/extension",
    "build:backend": "npm run build --workspace=packages/backend",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.6.2"
}
